{
  "__inputs": [
    {
      "name": "DS_CLOUDWATCH",
      "label": "CloudWatch",
      "type": "datasource",
      "pluginId": "cloudwatch",
      "pluginName": "CloudWatch"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "9.0.0" },
    { "type": "datasource", "id": "cloudwatch", "name": "CloudWatch", "version": "1.0.0" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "refresh": "5m",
  "schemaVersion": 38,
  "tags": ["aws", "vpc", "networking", "subnet-watcher"],
  "time": { "from": "now-3h", "to": "now" },
  "timepicker": {},
  "timezone": "",
  "title": "Subnet Watcher",
  "uid": "subnet-watcher-v1",
  "version": 1,
  "templating": {
    "list": [
      {
        "current": {},
        "hide": 0,
        "includeAll": false,
        "label": "CloudWatch Datasource",
        "multi": false,
        "name": "datasource",
        "options": [],
        "query": "cloudwatch",
        "refresh": 1,
        "type": "datasource"
      },
      {
        "current": {},
        "datasource": { "type": "cloudwatch", "uid": "${datasource}" },
        "definition": "regions()",
        "hide": 0,
        "includeAll": false,
        "label": "Region",
        "multi": false,
        "name": "region",
        "options": [],
        "query": "regions()",
        "refresh": 1,
        "type": "query"
      }
    ]
  },
  "panels": [
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 0 },
      "id": 10,
      "title": "IP Availability",
      "type": "row"
    },
    {
      "datasource": { "type": "cloudwatch", "uid": "${datasource}" },
      "description": "% of IPs remaining per subnet. Red zone = below 20% (warning threshold).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": {
            "lineWidth": 2,
            "fillOpacity": 8,
            "thresholdsStyle": { "mode": "line+area" }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "green", "value": 50 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 10, "w": 24, "x": 0, "y": 1 },
      "id": 1,
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "min"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "asc" }
      },
      "targets": [
        {
          "alias": "{{SubnetId}} | {{VPCId}}",
          "datasource": { "type": "cloudwatch", "uid": "${datasource}" },
          "dimensions": { "SubnetId": ["*"], "VPCId": ["*"] },
          "matchExact": false,
          "metricEditorMode": 0,
          "metricName": "AvailableIpAddressPercent",
          "metricQueryType": 0,
          "namespace": "VPCSubnetMetrics",
          "period": "300",
          "refId": "A",
          "region": "${region}",
          "statistic": "Average"
        }
      ],
      "title": "Available IP % per Subnet",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "cloudwatch", "uid": "${datasource}" },
      "description": "Raw count of available IPs per subnet.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "short",
          "min": 0,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 11 },
      "id": 2,
      "options": {
        "legend": {
          "calcs": ["lastNotNull", "min"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "asc" }
      },
      "targets": [
        {
          "alias": "{{SubnetId}} | {{VPCId}}",
          "datasource": { "type": "cloudwatch", "uid": "${datasource}" },
          "dimensions": { "SubnetId": ["*"], "VPCId": ["*"] },
          "matchExact": false,
          "metricEditorMode": 0,
          "metricName": "AvailableIpAddressCount",
          "metricQueryType": 0,
          "namespace": "VPCSubnetMetrics",
          "period": "300",
          "refId": "A",
          "region": "${region}",
          "statistic": "Average"
        }
      ],
      "title": "Available IPs per Subnet",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "cloudwatch", "uid": "${datasource}" },
      "description": "Total usable IPs per subnet (CIDR size minus 5 AWS-reserved addresses).",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "short",
          "min": 0,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 11 },
      "id": 3,
      "options": {
        "legend": {
          "calcs": ["lastNotNull"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "asc" }
      },
      "targets": [
        {
          "alias": "{{SubnetId}} | {{VPCId}}",
          "datasource": { "type": "cloudwatch", "uid": "${datasource}" },
          "dimensions": { "SubnetId": ["*"], "VPCId": ["*"] },
          "matchExact": false,
          "metricEditorMode": 0,
          "metricName": "TotalIpAddressCount",
          "metricQueryType": 0,
          "namespace": "VPCSubnetMetrics",
          "period": "300",
          "refId": "A",
          "region": "${region}",
          "statistic": "Average"
        }
      ],
      "title": "Total IPs per Subnet",
      "type": "timeseries"
    },
    {
      "collapsed": false,
      "gridPos": { "h": 1, "w": 24, "x": 0, "y": 19 },
      "id": 11,
      "title": "Network Interfaces",
      "type": "row"
    },
    {
      "datasource": { "type": "cloudwatch", "uid": "${datasource}" },
      "description": "Detached (available, not in-use) ENIs per VPC. High counts may indicate cleanup opportunity.",
      "fieldConfig": {
        "defaults": {
          "color": { "mode": "palette-classic" },
          "custom": { "lineWidth": 2, "fillOpacity": 8 },
          "unit": "short",
          "min": 0,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 20 },
      "id": 4,
      "options": {
        "legend": {
          "calcs": ["lastNotNull"],
          "displayMode": "table",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": { "mode": "multi", "sort": "asc" }
      },
      "targets": [
        {
          "alias": "{{VPCId}}",
          "datasource": { "type": "cloudwatch", "uid": "${datasource}" },
          "dimensions": { "VPCId": ["*"] },
          "matchExact": false,
          "metricEditorMode": 0,
          "metricName": "AvailableNetworkInterface",
          "metricQueryType": 0,
          "namespace": "VPCSubnetMetrics",
          "period": "300",
          "refId": "A",
          "region": "${region}",
          "statistic": "Average"
        }
      ],
      "title": "Available (Detached) ENIs per VPC",
      "type": "timeseries"
    },
    {
      "datasource": { "type": "cloudwatch", "uid": "${datasource}" },
      "description": "Current snapshot: latest available IP % per subnet.",
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "thresholds"
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              { "color": "red", "value": null },
              { "color": "yellow", "value": 20 },
              { "color": "green", "value": 50 }
            ]
          },
          "unit": "percent",
          "min": 0,
          "max": 100,
          "mappings": []
        },
        "overrides": []
      },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 20 },
      "id": 5,
      "options": {
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "alias": "{{SubnetId}}",
          "datasource": { "type": "cloudwatch", "uid": "${datasource}" },
          "dimensions": { "SubnetId": ["*"], "VPCId": ["*"] },
          "matchExact": false,
          "metricEditorMode": 0,
          "metricName": "AvailableIpAddressPercent",
          "metricQueryType": 0,
          "namespace": "VPCSubnetMetrics",
          "period": "300",
          "refId": "A",
          "region": "${region}",
          "statistic": "Average"
        }
      ],
      "title": "Current IP % per Subnet",
      "type": "stat"
    }
  ]
}
